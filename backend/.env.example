APP_NAME=Suspicious Link Checker API
APP_ENV=dev
APP_DEBUG=false
API_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173
# Production: comma-separated origins, e.g. https://your-app.vercel.app
# CORS_ORIGINS=
# Optional: allow all Vercel preview deployments (regex)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=
WHOIS_API_KEY=

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=link_checker

REQUEST_TIMEOUT_MS=8000
MAX_URL_LENGTH=2048
ALLOWED_SCHEMES=http,https
MAX_CONCURRENT_PROVIDER_CALLS=4
ENABLE_SCAN_PERSISTENCE=true

PRIVATE_NETWORK_SCAN_ALLOWED=false
LOOPBACK_SCAN_ALLOWED=false
VT_MALICIOUS_OVERRIDE_THRESHOLD=5
